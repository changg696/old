-- Classify battle each tick
local function classifyBattle(battle)
	local BDG = Runtime.BattleDataGetModule
	local bt = battle.type
	local catchInfo = nil
	if BDG and BDG.getLocalPlayerCatchPetInfo then
		local ok,ci = pcall(BDG.getLocalPlayerCatchPetInfo, battle); if ok then catchInfo=ci end
	end
	local selfPet
	local mbw = Runtime.getController("MainBattleWindowController")
	if mbw and mbw.getLocalCurrentSelfPet then
		local ok,p = pcall(mbw.getLocalCurrentSelfPet, battle); if ok then selfPet=p end
	end
	return {
		battle=battle, battleType=bt,
		isWild   = (bt==BTYPE.PVE_PET) and (catchInfo~=nil),
		isNpc    = (bt==BTYPE.PVE_NPC),
		isBoss   = (bt==BTYPE.PVE_BOSS),
		isDungeon= (bt==BTYPE.PVE_DUNGEON),
		catchPetInfo=catchInfo,
		selfActivePet=selfPet,
	}
end

local function isAlive(pet)
	if not pet then return false end
	local BDG = Runtime.BattleDataGetModule
	if BDG and BDG.isAliveBattlePet then
		local ok,r = pcall(BDG.isAliveBattlePet, pet); if ok then return r end
	end
	return pet.aliveState == (CC and CC.AliveState and CC.AliveState.ALIVE or 1)
end

-- classify mutation of a catch target.
-- Shiny: catchPetInfo.isShiny (set by game), fallback to PetConfig.shinyTypeId==2.
-- Prismatic ("colorful"): colorId>0 AND patternId>0.
local function classifyMutation(catchInfo)
	if not catchInfo then return { shiny=false, prismatic=false } end
	local shiny = catchInfo.isShiny == true
	if not shiny and catchInfo.configId and Runtime.ConfigDataManager and Runtime.ConfigConst then
		local ok,cfg = pcall(Runtime.ConfigDataManager.getConfig, Runtime.ConfigConst.ConfigName.PET, catchInfo.configId)
		if ok and cfg and cfg.shinyTypeId == 2 then shiny = true end
	end
	local prismatic = (typeof(catchInfo.colorId)=="number" and catchInfo.colorId > 0)
		and (typeof(catchInfo.patternId)=="number" and catchInfo.patternId > 0)
	return { shiny = shiny, prismatic = prismatic and true or false }
end

local function ballOwned(itemId)
	if not itemId then return false end
	if itemId == Runtime.BALL.NORMAL then return true end -- infinite
	if not Runtime.BagService then return false end
	local ok,n = pcall(Runtime.BagService.getItemNumById, itemId)
	return ok and typeof(n)=="number" and n > 0
end

local function pickBallForMutation(mut)
	local cfg = HubState.ballConfig
	local want
	if mut.shiny and mut.prismatic then want = cfg.shinyPrismatic or cfg.prismatic or cfg.shiny
	elseif mut.prismatic then want = cfg.prismatic
	elseif mut.shiny then want = cfg.shiny end
	if want and ballOwned(want) then return want end
	return Runtime.BALL.NORMAL -- always-throwable fallback
end
--Action dispatch (ONLY call-site that triggers a battle operate)
local function firstAliveBenchUid(battle)
	local BDG = Runtime.BattleDataGetModule
	if not (BDG and BDG.buildSelfBattlePetListForSwitch) then return nil end
	local ok,list = pcall(BDG.buildSelfBattlePetListForSwitch, battle)
	if not ok or typeof(list)~="table" then return nil end
	for _,pet in ipairs(list) do
		if pet.isInField ~= true and isAlive(pet) then return pet.uid end
	end
	return nil
end

-- Operate gate: the game's controller silently no-ops applyUseSkill/applySwitchPet
local function canOperateNow(mbw)
	if not mbw then return false end
	if mbw.getCanOperate then
		local ok, v = pcall(mbw.getCanOperate)
		if ok then return v == true end
	end
	return true -- getter missing: assume operable (old behaviour)
end

local function doSwitch(battle, forced)
	local mbw = Runtime.getController("MainBattleWindowController")
	if not (mbw and mbw.applySwitchPet) then return false end
	if not forced and not canOperateNow(mbw) then return false end
	local uid = firstAliveBenchUid(battle)
	if not uid then return false end
	local pos
	local BDG = Runtime.BattleDataGetModule
	if forced and BDG and BDG.getLocalForceSwitchSlotPos then
		local ok,p = pcall(BDG.getLocalForceSwitchSlotPos, battle); if ok then pos=p end
	end
	local ok, submitted = pcall(mbw.applySwitchPet, uid, pos, forced and true or false)
	if not ok then return false end
	return submitted ~= false
end


local function resyncIfBattleNotFound(code)
	if code ~= 27801 then return false end
	local BS = Runtime.BattleService
	if BS and BS.clearBattleMirror then pcall(BS.clearBattleMirror) end
	return true
end

local THROW_COOLDOWN = 1.6
local function doCatch(ctx)
	local mbw = Runtime.getController("MainBattleWindowController")
	if not (mbw and mbw.applyCatchPetWithResult) then return false end
	local info = ctx.catchPetInfo
	if not info or not info.pos then return false end
	local cs = HubState._catchState
	local BS = Runtime.BattleService
	local b = ctx.battle
	-- throttle: hold off if we threw very recently (animation still playing). While we wait,
	-- keep poking animation-complete so the lock is cleared by the time the cooldown elapses.
	local nowc = os.clock()
	if cs._lastThrowAt and (nowc - cs._lastThrowAt) < THROW_COOLDOWN then
		if BS and BS.sendAnimationComplete and b then pcall(BS.sendAnimationComplete, b.round) end
		return false, 27811   -- treat as "still animating", non-terminal, don't count
	end
	-- 1) clear the animation lock BEFORE throwing (the key fix)
	if BS and BS.sendAnimationComplete and b then pcall(BS.sendAnimationComplete, b.round) end
	local ball = pickBallForMutation(classifyMutation(info))
	cs._lastThrowAt = os.clock()
	local ok, code = pcall(mbw.applyCatchPetWithResult, info.pos, ball)
	if not ok then return false end
	-- Non-terminal codes
	if code ~= nil and code ~= 27813 and code ~= 27814 then
		if code == 27811 and BS and BS.sendAnimationComplete and b then
			pcall(BS.sendAnimationComplete, b.round)
		end
		resyncIfBattleNotFound(code)
		return false, code
	end
	return true, code   -- code: 27813=success, 27814=fail
end

local function ensureServerAuto(battle)
	local BS = Runtime.BattleService
	if not (BS and BS.autoBattle) then return false end
	local st = HubState._autoBattleState
	local buid = battle and battle.uid or "cur"
	if st.buid == buid and st.enabled then return true end   -- already enabled this battle
	local ok, code = pcall(BS.autoBattle, true)
	if ok and (code == 20000 or code == nil) then
		st.buid = buid; st.enabled = true
		return true
	end
	resyncIfBattleNotFound(code)
	return false
end

local NUDGE_COOLDOWN_NORMAL, NUDGE_COOLDOWN_FAST = 2.0, 0.4
local _lastNudgeAt = 0
local function nudgeStrongestSkill(ctx)
	local mbw = Runtime.getController("MainBattleWindowController")
	if not (mbw and mbw.applyUseSkill) then return end
	if not canOperateNow(mbw) then return end
	local nown = os.clock()
	local cooldown = HubState.toggles.fastBattle and NUDGE_COOLDOWN_FAST or NUDGE_COOLDOWN_NORMAL
	if (nown - _lastNudgeAt) < cooldown then return end
	local self = ctx.selfActivePet
	if not self or typeof(self.skills)~="table" then return end
	local enemy
	if mbw.getCurrentEnemyPet then local ok,e=pcall(mbw.getCurrentEnemyPet, ctx.battle); if ok then enemy=e end end
	local SAM = Runtime.SkillAreaModule
	-- energy gate for ultimates (skills with pp==nil are energy-gated ultimates)
	local energy = 0
	local BDG = Runtime.BattleDataGetModule
	if BDG and BDG.getLocalPlayerTrainer then
		local ok,tr = pcall(BDG.getLocalPlayerTrainer, ctx.battle)
		if ok and tr and typeof(tr.energy)=="number" then energy = tr.energy end
	end
	local best, bestPow = nil, -1
	if SAM and SAM.rebuildOperableSkillPowerCache then
		local cache = { powerMap = {} }
		pcall(SAM.rebuildOperableSkillPowerCache, cache, self, enemy, false)
		for _,sk in ipairs(self.skills) do
			if typeof(sk)=="table" and sk.id then
				local ppOk = (sk.pp==nil) or (sk.pp>0)
				local eCost = 0
				if Runtime.ConfigDataManager and Runtime.ConfigConst then
					local ok,cfg = pcall(Runtime.ConfigDataManager.getConfig, Runtime.ConfigConst.ConfigName.SKILL, sk.id)
					if ok and cfg and typeof(cfg.energyCost)=="number" then eCost = cfg.energyCost end
				end
				local pow = cache.powerMap[sk.id]
				if ppOk and eCost<=energy and pow and pow>bestPow then bestPow=pow; best=sk.id end
			end
		end
	end
	if best then
		-- stamp the cooldown on EVERY attempt (even a rejected one), so a 27811 can't be
		-- re-fired 0.15s later. The nudge is purely optional — server auto still fights.
		_lastNudgeAt = os.clock()
		pcall(mbw.applyUseSkill, best)
	end
end

-- doSkill: ensure server auto is on (the reliable driver), then nudge strongest skill.
-- Returns true if server auto is active so the loop counts it as handled.
local function doSkill(ctx)
	local autoOn = ensureServerAuto(ctx.battle)
	nudgeStrongestSkill(ctx)   -- best-effort damage 
	return autoOn
end

local function giveUpCatch(ctx)
	local BS = Runtime.BattleService
	if not BS or not ATYPE.GIVE_UP_CATCH then return false end
	local info = ctx.catchPetInfo
	local selfPos = (ctx.selfActivePet and ctx.selfActivePet.pos) or 1
	local ok, code = pcall(BS.operateBattle, {
		actionType = ATYPE.GIVE_UP_CATCH, sourcePos = selfPos, targetPos = info and info.pos,
	})
	if ok then resyncIfBattleNotFound(code) end
	return ok
end

local function decideAndAct(ctx, tg)
	local st = ctx.battle.status
	local actionable = (st==STATUS.WAIT_OPERATION or st==STATUS.WAIT_FORCE_CALL
		or st==STATUS.ROUND_START_FORCE_CALL or st==STATUS.ROUND_END_FORCE_CALL
		or st==STATUS.CATCH_PET)
	if not actionable then return nil end

	-- 2. forced switch window (preempts all)
	if st==STATUS.WAIT_FORCE_CALL or st==STATUS.ROUND_START_FORCE_CALL or st==STATUS.ROUND_END_FORCE_CALL then
		if tg.autoSwitchDeadPet and doSwitch(ctx.battle, true) then return "forceswitch" end
		return nil
	end

	-- 3. catch window (wild only) — ONLY during the dedicated CATCH_PET status.
	if st==STATUS.CATCH_PET and ctx.isWild then
		local info = ctx.catchPetInfo
		local buid = ctx.battle.uid or "cur"
		local cs = HubState._catchState
		if cs.buid ~= buid then 
			cs.buid = buid
			cs.local_tries = 0
			cs.done = false
			cs.phaseStart = os.clock()
			cs._lastThrowAt = nil 
		end
		cs.phaseStart = cs.phaseStart or os.clock()
		local maxCatch = (info and info.maxCatchCount) or 1
		local remain = maxCatch - cs.local_tries

		-- SAFETY: if the catch phase drags on too long (throws keep getting rejected, or
		if not cs.done and os.clock() - cs.phaseStart > 30 then
			cs.done = true
			if giveUpCatch(ctx) then return "giveup" end
			return nil
		end

		local mut = classifyMutation(info)
		--   shiny         -> mut.shiny
		--   prismatic     -> mut.prismatic
		--   shiny+prismatic -> mut.shiny AND mut.prismatic
		-- If ANY mutation toggle is on, ONLY matching pets are caught (a normal is skipped),
		-- UNLESS plain autoCatch is also explicitly on (then catch everything).
		-- If no mutation toggle is on, plain autoCatch catches all.
		local mutationHunt = tg.autoCatchShiny or tg.autoCatchPrismatic or tg.autoCatchShinyPrismatic
		local matchesMutation =
			(tg.autoCatchShiny and mut.shiny) or
			(tg.autoCatchPrismatic and mut.prismatic) or
			(tg.autoCatchShinyPrismatic and mut.shiny and mut.prismatic)
		local want
		if tg.autoCatch then
			want = true             
		elseif mutationHunt then
			want = matchesMutation and true or false
		else
			want = false   
		end
		local anyCatchOn = tg.autoCatch or mutationHunt

		if want and remain > 0 and not cs.done then
			local ok, code = doCatch(ctx)
			if ok then
				cs.local_tries += 1
				if code == 27813 then cs.done = true end   -- success -> stop
				return "catch"
			end
			return nil
		end
		if st==STATUS.CATCH_PET and not cs.done then
			cs.done = true
			if giveUpCatch(ctx) then return "giveup" end
		end
		return nil
	end

	if st==STATUS.CATCH_PET and not ctx.isWild then
		if giveUpCatch(ctx) then return "giveup" end
		return nil
	end


	if st==STATUS.WAIT_OPERATION and tg.autoSwitchDeadPet and not isAlive(ctx.selfActivePet) then
		if doSwitch(ctx.battle, false) then return "switch" end
	end

	if st==STATUS.WAIT_OPERATION and tg.autoSkill and isAlive(ctx.selfActivePet) then
		if doSkill(ctx) then return "skill" end
	end
	return nil
end

-- ---- Battle recovery helpers 
local function escapeBattle()
	local BS = Runtime.BattleService
	if not BS then return false end
	local rof = Runtime.ReqOperateBattle
	local BCc = Runtime.BattleConst
	if rof and BCc and BCc.ACTION_TYPE and BCc.ACTION_TYPE.ESCAPE then
		pcall(function() rof:InvokeServer({ actionType=BCc.ACTION_TYPE.ESCAPE, sourcePos=1 }) end)
	end
	task.wait(1.5)
	local canEnter = select(2, pcall(BS.canEnterBattle, 1))
	if canEnter == 20000 and BS.getCurrentBattle() ~= nil then
		pcall(function() BS.clearBattleMirror() end)
	end
	return BS.getCurrentBattle() == nil
end
HubState.escapeBattle = escapeBattle

local function repairBattleDesync()
	local BS = Runtime.BattleService
	if not BS then return end
	local canEnter = select(2, pcall(BS.canEnterBattle, 1))
	if canEnter == 27803 and BS.getCurrentBattle() == nil then
		local rof = Runtime.ReqOperateBattle
		local BCc = Runtime.BattleConst
		if rof and BCc and BCc.ACTION_TYPE and BCc.ACTION_TYPE.ESCAPE then
			pcall(function() rof:InvokeServer({ actionType=BCc.ACTION_TYPE.ESCAPE, sourcePos=1 }) end)
		end
		return true
	end
	return false
end
HubState.repairBattleDesync = repairBattleDesync

-- ---- The single BattleLoop
local BattleLoop = { running=false, _thread=nil, _battleUid=nil, _opArmed=true, _lastActedAt=0, _desyncCheck=0 }

-- kinds that are repeatable within the same (round,status) phase
local REPEATABLE = { catch=true, giveup=true, forceswitch=true }

function BattleLoop:tick()
	local battle = Runtime.getCurrentBattle()
	if not battle then
		if self._wasInBattle then
			self._wasInBattle = false
			if HubState.Pacing then 
				pcall(function() 
					HubState.Pacing:onBattleBoundary() 
				end) 
			end
		end
		HubState.currentBattle = nil
		self._battleUid = nil
		self._opArmed = true
		HubState._autoBattleState.enabled = false
		HubState._autoBattleState.buid = nil
		
		local hasAnyEnabled = HubState.toggles.farmEnabled 
			or HubState.toggles.npcEnabled 
			or HubState.toggles.bossEnabled 
			or HubState.toggles.towerEnabled
		if hasAnyEnabled
			and os.clock()-(self._desyncCheck or 0) > 5 then
			self._desyncCheck = os.clock()
			pcall(function() 
				if HubState.repairBattleDesync() then 
					HubState._notify("Recovered stuck battle session", "ok") 
				end 
			end)
		end
		return
	end
	self._wasInBattle = true
	if battle.status == STATUS.BATTLE_END then return end

	local ctx = classifyBattle(battle)
	HubState.currentBattle = { battle=battle, ctx=ctx }

	local tg = HubState.toggles
	local st = battle.status


	if self._battleUid ~= battle.uid then
		self._battleUid = battle.uid
		self._opArmed = true
		self._lastActedAt = 0
		if HubState.Pacing then pcall(function() HubState.Pacing:reassertSpeedFlag() end) end
		if HubState.toggles.autoSkill then pcall(ensureServerAuto, battle) end
	end

	local mbw = Runtime.getController("MainBattleWindowController")
	local canOp = true
	if mbw and mbw.getCanOperate then
		local ok,v = pcall(mbw.getCanOperate); if ok then canOp = (v==true) end
	end
	local RETRY_AFTER = (HubState.toggles.fastBattle) and 0.35 or 2.5

	if st==STATUS.WAIT_OPERATION then
		if not canOp then
			self._opArmed = true 
			return
		end
		if not self._opArmed then
			if os.clock() - (self._lastActedAt or 0) < RETRY_AFTER then return end
			self._opArmed = true
		end
	end
	local kind = decideAndAct(ctx, tg)
	if kind then
		HubState._debug.actions = (HubState._debug.actions or 0) + 1
		HubState._debug.last = os.clock()
		HubState._debug.lastKind = kind
		if kind=="skill" or kind=="switch" then
			self._opArmed = false
			self._lastActedAt = os.clock()
		end
		local postActWait
		if HubState.toggles.fastBattle then postActWait = REPEATABLE[kind] and 0.2 or 0.1
		else postActWait = REPEATABLE[kind] and 0.6 or 0.3 end
		task.wait(postActWait)
	end
end

function BattleLoop:start()
	if self.running then return end
	self.running = true
	self._thread = task.spawn(function()
		while self.running and not HubState._killed do
			local ok,err = pcall(function() self:tick() end)
			if not ok then warn("[JinHub] BattleLoop error: "..tostring(err)) end
			task.wait(HubState.toggles.fastBattle and 0.05 or 0.15)
		end
	end)
end

function BattleLoop:stop()
	self.running = false
end

