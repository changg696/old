local _npcListCache
local function challengeableNpcs()
	if _npcListCache then return _npcListCache end
	local CDM, CCn = Runtime.ConfigDataManager, Runtime.ConfigConst
	if not (CDM and CCn) then return {} end
	local ok, npcTable = pcall(CDM.getTable, CCn.ConfigName.NPC)
	if not ok or typeof(npcTable)~="table" then return {} end
	local function getTalk(id) local o,c=pcall(CDM.getConfig, CCn.ConfigName.TALK, id); return o and c or nil end
	local list = {}
	for id, npc in pairs(npcTable) do
		local seen, stack, found = {}, {}, nil
		for _,t in ipairs(npc.npcInitialDialogueId or {}) do stack[#stack+1]=t end
		while #stack > 0 do
			local tid = table.remove(stack)
			if not seen[tid] then seen[tid]=true
				local node = getTalk(tid)
				if node then
					if node.battleId then found=node.battleId; break end
					for _,nx in ipairs(node.nextTalkIds or {}) do stack[#stack+1]=nx end
				end
			end
		end
		if found then
			list[#list+1] = { npcId=id, name=npc.npcName or ("NPC "..id), isBoss=npc.isBoss==1, battleId=found }
		end
	end
	table.sort(list, function(a,b) return a.name < b.name end)
	_npcListCache = list
	return list
end

local function npcOptions(bossOnly)
	local opts = {}
	for _,n in ipairs(challengeableNpcs()) do
		if (bossOnly and n.isBoss) or (not bossOnly and not n.isBoss) then
			opts[#opts+1] = { label=n.name.." ("..tostring(n.npcId)..")", value=n.npcId }
		end
	end
	return opts
end

local function npcById(npcId)
