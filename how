local function claimActiveMilestone()
	local T = Runtime.TaskService
	if not (T and Runtime.ReqClaimActiveReward and T.getActivePoint and T.getActiveClaimIndex) then return false end
	-- claimable iff activePoint >= threshold of next unclaimed tier
	local okp, ap = pcall(T.getActivePoint)
	local oki, ci = pcall(T.getActiveClaimIndex)
	if not (okp and oki) then return false end
	-- read tier thresholds from ActiveRewardsConfig
	local claimable=false
	if Runtime.ConfigDataManager and Runtime.ConfigConst then
		local o,tbl = pcall(Runtime.ConfigDataManager.getTable, Runtime.ConfigConst.ConfigName.ACTIVE_REWARDS)
		if o and typeof(tbl)=="table" then
			-- next tier index = ci+1 ; find its activePoint threshold
			for _,tier in pairs(tbl) do
				if typeof(tier)=="table" and tier.id==(ci+1) and typeof(tier.activePoint)=="number" then
					claimable = (ap >= tier.activePoint); break
				end
			end
		end
	end
	if not claimable then return false end
	local bind = Runtime.ReqClaimActiveReward
	if bind and bind.Invoke then
		local o = pcall(function() return bind:Invoke() end)
		if o then return true end
	end
	local rem = Runtime.ReqClaimActiveRewardRemote
	if rem and rem.InvokeServer then
		local o = pcall(function() return rem:InvokeServer() end)
		return o and true or false
	end
	return false
end

local function questWorkList()
	local T = Runtime.TaskService
	if not (T and T.getTaskModuleData) then return {} end
	local ok, data = pcall(T.getTaskModuleData)
	if not ok or typeof(data)~="table" or typeof(data.taskList)~="table" then return {} end
	local plr = Players.LocalPlayer
	local list = {}
	for taskId, td in pairs(data.taskList) do
		if typeof(td)=="table" and td.status==2 then -- IN_PROGRESS
			-- skip ones already ready to claim (goals done) — claim loop takes them
			local allDone = false
			local o,_,done = pcall(T.checkAllGoalsCompletedByTaskId, plr, taskId)
			if o then allDone = done end
			if not allDone then
				local tc = getTaskCfg(taskId)
				list[#list+1] = {
					taskId = taskId,
					taskType = tc and tc.type or 99,
					title = (tc and tc.taskTitle) or ("Task "..tostring(taskId)),
					goals = taskGoalList(taskId),
				}
			end
		end
	end
	table.sort(list, function(a,b)
		if a.taskType ~= b.taskType then return a.taskType < b.taskType end -- MAIN(1) first
		return a.taskId < b.taskId
	end)
	return list
end

