local function resolveUIManager()
	if HubState._UIManager ~= nil then return HubState._UIManager, HubState._UIConst end
	local UIManager, UIConst
	for _,d in ipairs(RS:GetDescendants()) do
		if not UIManager and d.Name=="UIManager" and d:IsA("ModuleScript") then UIManager=safeRequire(d) end
		if not UIConst and d.Name=="UIConst" and d:IsA("ModuleScript") then UIConst=safeRequire(d) end
		if UIManager and UIConst then break end
	end
	HubState._UIManager = UIManager or false
	HubState._UIConst = UIConst or false
	return HubState._UIManager, HubState._UIConst
end

function Feature.cleanUpUI()
	local closed = {}
	local BCC = Runtime.BattleChoreoConst
	local choreo = Runtime.getController("BattleChoreoController")
	if choreo and choreo.forceAbortBattle and BCC and BCC.FORCE_ABORT_REASON then
		pcall(choreo.forceAbortBattle, BCC.FORCE_ABORT_REASON.QUEUE_STALLED, { source="JinHubCleanUp" })
	end
	pcall(function() HubState.repairBattleDesync() end)
	if Runtime.getCurrentBattle() ~= nil then pcall(function() HubState.escapeBattle() end) end
	local UIManager, UIConst = resolveUIManager()
