-- One Auto-Release cycle: lock protected pets, re-read, release the rest one at a time.
function Feature.autoReleasePass()
	autoLockPass()
	local map = getPetMap(); if not map then return 0 end
	local tg = HubState.toggles
	local released = 0
	for uuid, pet in pairs(map) do
		if HubState._killed or not HubState.toggles.autoRelease then break end
		local shiny, prism, grade = petIsShiny(pet), petIsPrismatic(pet), petGrade(pet)
		local keep = pet.locked or pet.loved
			or (tg.keepShiny and shiny)
			or (tg.keepPrismatic and prism)
			or (grade and tg.keepGrades[grade])
		local lockProtected = (tg.autoLockShiny and shiny) or (tg.autoLockPrismatic and prism) or (tg.autoLockSSS and grade=="SSS")
		if not keep and not lockProtected then
			local code = Feature.releaseOne(uuid)
			if code==20000 then released += 1 end
			task.wait(0.2)
		end
	end
	return released
end

