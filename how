do
	local running=false
	local lastResult = nil
	local resultConn
	local function hookResult()
		if resultConn then return end
		if Bindable and Bindable:FindFirstChild("Dungeon") and Bindable.Dungeon:FindFirstChild("CommTowerDungeonBattleResult") then
			resultConn = Bindable.Dungeon.CommTowerDungeonBattleResult.Event:Connect(function(dungeonId, isWin)
				lastResult = { dungeonId=dungeonId, isWin=isWin, at=os.clock() }
			end)
			table.insert(HubState._conns, resultConn)
		end
	end

	function Feature.startTowerLoop()
		if running then return end
		running=true
		hookResult()
		task.spawn(function()
			local entered=false
			while HubState.toggles.towerEnabled and not HubState._killed do
				local TW = Runtime.TowerService
				if not TW then HubState._notify("Tower service unavailable","err"); break end
				if not claimLock("tower") then task.wait(1); continue end

				local rs = select(2, pcall(TW.getCurrentRuntimeState))
				rs = (typeof(rs)=="table") and rs or {}

				if not rs.isInTower and not entered then
					local info = Feature.towerEntranceInfo()
					local maxSel = (info and info.maxSelectableLayer) or 1
					local startLayer = math.clamp(HubState.toggles.towerStartLayer or 1, 1, maxSel)
					lastResult = nil
					local ok, code = pcall(TW.startTowerDungeonFlow, startLayer)
					HubState._notify("Tower: entering layer "..startLayer, "ok")
					entered = true
					task.wait(2.5) -- scene load
				elseif rs.isInTower then
					entered = true
					local canBattle = select(2, pcall(TW.canEnterBattleNow))
					if canBattle==true and Runtime.getCurrentBattle()==nil then
						lastResult = nil
						pcall(TW.requestEnterBattle)
						local ts=os.clock()
						while Runtime.getCurrentBattle()==nil and os.clock()-ts<8 and not HubState._killed do task.wait(0.3) end
						local tb=os.clock()
						while Runtime.getCurrentBattle()~=nil and os.clock()-tb<180 and not HubState._killed do task.wait(0.4) end
						task.wait(1.2)
						local r = lastResult
						if r and r.isWin==false then
							if HubState.toggles.towerExitOnLoss then
								pcall(TW.requestExitTower, "AutoTowerLoss")
								HubState._notify("Tower: lost — exiting", nil)
								entered=false; task.wait(1)
							else
								HubState._notify("Tower: lost — retrying floor", nil)
							end
						elseif r and r.isWin==true then
							HubState._notify("Tower: floor cleared", "ok")
							task.wait(2)
						end
					else
						task.wait(1)
					end
				else
					task.wait(1)
				end
			end
			pcall(function()
				local TW=Runtime.TowerService
				if TW and TW.getCurrentRuntimeState then
					local rs = select(2, pcall(TW.getCurrentRuntimeState))
					if typeof(rs)=="table" and rs.isInTower then TW.requestExitTower("AutoTowerOff") end
				end
			end)
			releaseLock("tower")
			running=false
		end)
	end
end

