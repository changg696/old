	end
	local _, hrp = getCharacter()
	if hrp and worldPos then
		pcall(function() hrp.CFrame = CFrame.new(worldPos + Vector3.new(0, 4, 6)) end)
		task.wait(0.25)
	end
	fireWildEntry(uid)
	local ts=os.clock()
	while Runtime.getCurrentBattle()==nil and os.clock()-ts < 6 do
		if not HubState.activityLock then return false end
		if os.clock()-ts > 3 and Runtime.getCurrentBattle()==nil then fireWildEntry(uid) end
		task.wait(0.2)
	end
	if Runtime.getCurrentBattle()==nil then return false end
	local tb=os.clock()
	while Runtime.getCurrentBattle()~=nil and os.clock()-tb < 150 do task.wait(0.4) end
	return true
end

