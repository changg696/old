-- Auto Lock pass
local function autoLockPass()
	local PS = Runtime.PetService
	if not (PS and PS.reqSetPetLocked) then return end
	local tg = HubState.toggles
	if not (tg.autoLockShiny or tg.autoLockPrismatic or tg.autoLockSSS) then return end
	local map = getPetMap(); if not map then return end
	for uuid, pet in pairs(map) do
