-- list currently-spawned wild pet configId
local function liveWildPetOptions()
	local opts = {}
	if not (CSS and CreatureConst) then return opts end
	local a,b = CSS.getCreatureListByType(CreatureConst.CreatureType.WILD_PET)
	local map = (typeof(a)=="table") and a or (typeof(b)=="table") and b or nil
	if not map then return opts end
	local seen = {}
	for _,e in pairs(map) do
		if e.configId and not seen[e.configId] then
			seen[e.configId] = true
			local nm = "Pet "..tostring(e.configId)
			if Runtime.ConfigDataManager and Runtime.ConfigConst then
				local ok,cfg = pcall(Runtime.ConfigDataManager.getConfig, Runtime.ConfigConst.ConfigName.PET, e.configId)
				if ok and cfg and cfg.name then nm = cfg.name.." ("..tostring(e.configId)..")" end
			end
			opts[#opts+1] = { label=nm, value=e.configId }
		end
	end
	table.sort(opts, function(x,y) return x.label < y.label end)
	return opts
end

local function familyKey(configId)
	if typeof(configId)~="number" then return configId end
	return configId % 100000
end

local function isShinyConfig(configId)
	if not (Runtime.ConfigDataManager and Runtime.ConfigConst) then return false end
	local ok,cfg = pcall(Runtime.ConfigDataManager.getConfig, Runtime.ConfigConst.ConfigName.PET, configId)
	return ok and cfg and cfg.shinyTypeId == 2 or false
end

local function nearestWild(opts)
	opts = opts or {}
	if not (CSS and CreatureConst) then return nil end
	local _,map = CSS.getCreatureListByType(CreatureConst.CreatureType.WILD_PET)
	if typeof(map)~="table" then return nil end
	local _,hrp = getCharacter()
	if not hrp then return nil end
	local myPos = hrp.Position
	local bestUid, bestE, bestD = nil, nil, math.huge
	for uid,e in pairs(map) do
		if e.aliveState==CreatureConst.AliveState.ALIVE and not e.isCombating and e.pos then
			local famOk = (opts.family==nil) or (familyKey(e.configId)==opts.family)
			local shinyOk = (not opts.requireShiny) or isShinyConfig(e.configId)
			if famOk and shinyOk then
				local d = myPos - e.pos.Position
				local flat = math.sqrt(d.X*d.X + d.Z*d.Z)
				if flat < bestD then bestD=flat; bestUid=uid; bestE=e end
			end
		end
	end
	return bestUid, bestE, bestD
end

local function listWilds()
	local out = {}
	if not (CSS and CreatureConst) then return out end
	local _,map = CSS.getCreatureListByType(CreatureConst.CreatureType.WILD_PET)
	if typeof(map)~="table" then return out end
	local _,hrp = getCharacter()
	local myPos = hrp and hrp.Position
	for uid,e in pairs(map) do
		if e.aliveState==CreatureConst.AliveState.ALIVE and not e.isCombating and e.pos then
			local d = myPos and (myPos - e.pos.Position) or nil
			local flat = d and math.sqrt(d.X*d.X + d.Z*d.Z) or math.huge
			out[#out+1] = { uid=uid, e=e, family=familyKey(e.configId), dist=flat,
				level=tonumber(e.level) or 0 }
		end
	end
	table.sort(out, function(a,b) return a.dist < b.dist end)
	return out
end

local function teamLeadLevel()
	local PGS = Runtime.PetGroupService
	local PS = Runtime.PetStorage
	if not (PGS and PS and PS.getPetList) then return 0 end
	local gid = select(2, pcall(PGS.getCurrentGroupId)) or 1
	local ok, grp = pcall(PGS.getPetGroupByGroupId, gid)
	if not (ok and typeof(grp)=="table" and typeof(grp.petUuids)=="table") then return 0 end
	local u = grp.petUuids[1] or grp.petUuids["1"]
	local list = PS.getPetList()
	local p = type(list)=="table" and u and list[u]
	return p and (tonumber(p.level) or 0) or 0
end

HubState._famStats = HubState._famStats or {}
HubState._famBlacklist = HubState._famBlacklist or {}
local OpponentPicker = {}
OpponentPicker.SLOW_THRESHOLD = 25 
OpponentPicker.MAX_STRIKES = 2   

function OpponentPicker.reset()
	HubState._famStats = {}
	HubState._famBlacklist = {}
end
function OpponentPicker.recordBattleResult(family, won, dur)
	if family==nil then return end
	local s = HubState._famStats[family]
	if not s then s = { wins=0, losses=0, sumWinTime=0, slowStrikes=0 }; HubState._famStats[family]=s end
	if won then
		s.wins += 1
		s.sumWinTime += (dur or 0)
		if dur and dur > OpponentPicker.SLOW_THRESHOLD then s.slowStrikes += 1 end
	else
		s.losses += 1
		s.slowStrikes += 1
	end
	if s.slowStrikes >= OpponentPicker.MAX_STRIKES then
		HubState._famBlacklist[family] = true
	end
end
function OpponentPicker.pickOwnFarmWild()
	local wilds = listWilds()
	if #wilds == 0 then return nil end
	local lead = teamLeadLevel()
	local levelCap = lead > 0 and (lead + 3) or math.huge 
	local function score(w)
		if HubState._famBlacklist[w.family] then return -math.huge end
		local s = HubState._famStats[w.family]
		local base
		if not s or s.wins == 0 then base = 0             
		else
			local avg = s.sumWinTime / math.max(1, s.wins)
			base = 1000 - avg - (s.losses * 50)              
		end
		if w.level > 0 and lead > 0 then
			if w.level > levelCap then base = base - 500 - (w.level - levelCap)
				else base = base + (levelCap - w.level) end
			end
		return base
	end
	local best, bestScore
	for _,w in ipairs(wilds) do
		local sc = score(w)
		if sc > -math.huge and (bestScore==nil or sc > bestScore or (sc==bestScore and best and w.dist < best.dist)) then
			best, bestScore = w, sc
		end
	end
	if not best then return nil end 
	return best.uid, best.e
end
HubState.OpponentPicker = OpponentPicker

