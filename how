	if Runtime.GetBallDataModule and Runtime.GetBallDataModule.getBallInfoList then
		local ok,list = pcall(Runtime.GetBallDataModule.getBallInfoList)
		if ok and typeof(list)=="table" then
			for _,b in ipairs(list) do
				local nm = names[b.itemId] or ("Ball "..tostring(b.itemId))
