function Feature.islandBossOptions()
	local opts = {}
	local CDM, CCn, NC = Runtime.ConfigDataManager, Runtime.ConfigConst, Runtime.NpcConst
	if not (CDM and CCn and NC and NC.BOSS_TYPE) then return opts end
	local ok, all = pcall(CDM.getTable, CCn.ConfigName.NPC)
	if not ok or typeof(all)~="table" then return opts end
	local list = {}
	for npcId, cfg in pairs(all) do
		if cfg.bossType == NC.BOSS_TYPE.ISLAND_ELITE then
			list[#list+1] = { npcId=npcId, name=cfg.npcHeadShowName or cfg.npcName or ("Boss "..tostring(npcId)) }
		end
	end
	table.sort(list, function(a,b) return a.npcId < b.npcId end)
	for _,b in ipairs(list) do opts[#opts+1] = { label=b.name.." ("..tostring(b.npcId)..")", value=b.npcId } end
	return opts
end

-- resolve npcId -> battleId via BattlePool.positionTrainers[1]==npcId (cached)
local _bossBattleIdMap
local function bossBattleId(npcId)
	if not _bossBattleIdMap then
		_bossBattleIdMap = {}
		local CDM, CCn = Runtime.ConfigDataManager, Runtime.ConfigConst
		if CDM and CCn then
			local ok, pool = pcall(CDM.getTable, CCn.ConfigName.BATTLE_POOL)
			if ok and typeof(pool)=="table" then
				for battleId, cfg in pairs(pool) do
					if typeof(cfg.positionTrainers)=="table" and cfg.positionTrainers[1] then
						_bossBattleIdMap[cfg.positionTrainers[1]] = battleId
					end
				end
			end
		end
	end
	return _bossBattleIdMap[npcId]
end
HubState.bossBattleId = bossBattleId

