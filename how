-- challenge an NPC
local function challengeNpc(n)
	local BS = Runtime.BattleService
	if not (BS and BS.enterActualNpcBattle) then return false end
	-- pre-flight
	local battleType
	if DialogueService and DialogueService.getBattleTypeByBattleId then
		local ok,bt = pcall(DialogueService.getBattleTypeByBattleId, n.battleId); if ok then battleType=bt end
	end
	if battleType and BS.canEnterBattle then
		local ok,code = pcall(BS.canEnterBattle, battleType)
		if ok and code ~= 20000 then return false end
	end
	local leadUid = currentLeadPetUid()
	if not leadUid then return false end
	pcall(BS.enterActualNpcBattle, n.npcId, n.battleId, leadUid)
	local ts=os.clock()
	while Runtime.getCurrentBattle()==nil and os.clock()-ts < 6 do task.wait(0.2) end
	if Runtime.getCurrentBattle()==nil then return false end
	local tb=os.clock()
	while Runtime.getCurrentBattle()~=nil and os.clock()-tb < 150 do task.wait(0.4) end
	return true
end

