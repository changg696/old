local BOSS_STATE_PATH = "Nousigi/BossFarmState.json"
function Feature.saveBossState()
	if typeof(writefile)~="function" then return end
	if typeof(isfolder)=="function" and not isfolder("Nousigi") then pcall(makefolder, "Nousigi") end
	local tg = HubState.toggles
	local data = {
		autoFarmBoss = tg.bossEnabled and true or false,
		autoHopBoss  = tg.autoHopBoss and true or false,
		bossId       = tg.bossTargetId,
		hopCooldownSec = tg.hopCooldownSec or 20,
		savedAt = os.time(),
	}
	pcall(writefile, BOSS_STATE_PATH, HttpService:JSONEncode(data))
end
function Feature.loadBossState()
	if typeof(isfile)~="function" or typeof(readfile)~="function" then return nil end
	if not isfile(BOSS_STATE_PATH) then return nil end
	local ok, raw = pcall(readfile, BOSS_STATE_PATH)
	if not ok or not raw or raw=="" then return nil end
	local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
	return ok2 and data or nil
end

do
	local running=false
	function Feature.startBossHopLoop()
		if running then return end
		running=true
		task.spawn(function()
			local lastHopAt = 0
			while not HubState._killed do
				local tg = HubState.toggles
				if tg.autoHopBoss and tg.bossEnabled and tg.bossTargetId then
					if not Feature.isBossAvailable(tg.bossTargetId) and Runtime.getCurrentBattle()==nil then
						local cd = tg.hopCooldownSec or 20
						if os.clock()-lastHopAt >= cd then
							lastHopAt = os.clock()
							Feature.saveBossState()
