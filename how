function HubState.bossById(npcId)
	if not _islandBossById then
		_islandBossById = {}
		local CDM, CCn, NC = Runtime.ConfigDataManager, Runtime.ConfigConst, Runtime.NpcConst
		if CDM and CCn and NC and NC.BOSS_TYPE then
			local ok, all = pcall(CDM.getTable, CCn.ConfigName.NPC)
			if ok and typeof(all)=="table" then
				for id, cfg in pairs(all) do
