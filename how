				or (tg.autoLockPrismatic and petIsPrismatic(pet))
				or (tg.autoLockSSS and petGrade(pet)=="SSS")
			if want then pcall(PS.reqSetPetLocked, uuid, true); task.wait(0.1) end
		end
	end
