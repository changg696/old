local function planQuestAction(q)
	local firstManual = nil
	for _,g in ipairs(q.goals) do
		local ty = g.cfg.type
		local params = g.cfg.params
		if ty==GOAL_TYPE.COMPLETE_BATTLE_WIN or ty==GOAL_TYPE.COMPLETE_BATTLE then
			local bid = params and params[1]
			local npc = npcByBattleId(bid)
			if npc then return {kind="challenge", npc=npc, goalId=g.id} end
		elseif ty==GOAL_TYPE.COMPLETE_TYPE_BATTLE_WIN then
			local p = params and params[1]
			if p==4 then return {kind="anyNpc"} else return {kind="anyBoss"} end
		elseif ty==GOAL_TYPE.OBTAIN_PET_SHINY then
			return {kind="shiny"}
		elseif ty==GOAL_TYPE.OBTAIN_PET_SPARKLE then
			return {kind="prismatic"}
		elseif ty==GOAL_TYPE.DEFEAT_ENEMY or ty==GOAL_TYPE.OBTAIN_PET
			or ty==GOAL_TYPE.OBTAIN_PET_CATCH then
			local fam = params and params[1]
			return {kind="farm", family=fam}
		elseif ty==GOAL_TYPE.PET_OWNED then
			return {kind="own", level=(params and params[1]) or 1, count=g.cfg.target or 1, goalId=g.id}
		elseif ty==GOAL_TYPE.PET_LEVEL_REACH then
			return {kind="own", level=(params and params[1]) or 1, count=1, goalId=g.id}
		elseif ty==GOAL_TYPE.ITEM_OBTAIN then
			return {kind="buyitem", itemId=params and params[1], count=g.cfg.target or 1, goalId=g.id}
		elseif ty==GOAL_TYPE.OPEN_CHEST then
			return {kind="chest"}
		elseif ty==GOAL_TYPE.TOWER_FLOOR then
			return {kind="tower", floor=g.cfg.target}
		elseif ty==GOAL_TYPE.ISLAND_REACH then
			return {kind="island", islandId=params and params[1], goalId=g.id}
		elseif ty==GOAL_TYPE.TALK_TO_NPC then
			return {kind="talk", npcId=params and params[1], goalId=g.id}
		elseif ty==GOAL_TYPE.PET_FEED then
			return {kind="feed"}
		elseif ty==GOAL_TYPE.COMPLETE_DUNGEON or ty==GOAL_TYPE.CLEAR_TAG_DUNGEON then
			local did = params and params[1]
			return {kind="dungeon", dungeonId=did, goalId=g.id}
		elseif ty==GOAL_TYPE.PLAYER_TIER then
			return {kind="ascend", tier=params and params[1], goalId=g.id}
		elseif MANUAL_GOAL_TYPES[ty] and not firstManual then
			firstManual = GOAL_TYPE_NAME[ty] or ("type "..tostring(ty))
		end
	end
	if firstManual then return {kind="manual", reason=firstManual} end
	return nil
end

