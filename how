local function driveQuestAction(plan, q)
	if plan.kind=="challenge" then
		if HubState.activityLock and HubState.activityLock~="quest" then return "busy" end
		if not claimLock("quest") then return "busy" end
		if Runtime.getCurrentBattle()~=nil then releaseLock("quest"); return "in-battle" end
		HubState._notify("Quest: "..q.title, "ok")
		local fought = challengeNpc(plan.npc)
		releaseLock("quest")
		return fought and "fought" or "challenge-failed"

	elseif plan.kind=="anyNpc" or plan.kind=="anyBoss" then
		-- pick any challengeable target of the right kind and fight
		if HubState.activityLock and HubState.activityLock~="quest" then return "busy" end
		if not claimLock("quest") then return "busy" end
		if Runtime.getCurrentBattle()~=nil then releaseLock("quest"); return "in-battle" end
		local target
		for _,n in ipairs(challengeableNpcs()) do
			if plan.kind=="anyBoss" and n.isBoss then target=n; break end
			if plan.kind=="anyNpc" and not n.isBoss then target=n; break end
		end
		if not target then releaseLock("quest"); return "no-target" end
		HubState._notify("Quest: "..q.title, "ok")
		local fought = challengeNpc(target)
		releaseLock("quest")
		return fought and "fought" or "challenge-failed"

	elseif plan.kind=="farm" then
		-- target the goal's pet family if given, then run the farm loop
		if plan.family then 
			HubState.toggles.farmTargetConfigId = plan.family 
		end
		if not HubState.toggles.farmEnabled then
			HubState.toggles.autoCatch = true
			HubState.toggles.farmEnabled = true
			local controls = HubState._configControls
			if controls and controls.farmEnabled then
				pcall(function() 
					controls.farmEnabled.handle:SetSilent(true) 
				end)
			end
			HubState.Engage.farm.start()
		end
		return "farming"

	elseif plan.kind=="shiny" or plan.kind=="prismatic" then
		local key = (plan.kind=="shiny") and "autoCatchShiny" or "autoCatchPrismatic"
		HubState.toggles[key] = true
		if not HubState.toggles.farmEnabled then
			HubState.toggles.farmEnabled = true
			local controls = HubState._configControls
			if controls and controls.farmEnabled then
				pcall(function() 
					controls.farmEnabled.handle:SetSilent(true) 
				end)
			end
			HubState.Engage.farm.start()
		end
		return plan.kind.."-hunt"

	elseif plan.kind=="chest" then
		pcall(Feature.claimAllChests)
		return "chests"

	elseif plan.kind=="tower" then
		if not HubState.toggles.towerEnabled then
			HubState.toggles.towerEnabled = true
			local controls = HubState._configControls
			if controls and controls.towerEnabled then
				pcall(function() 
					controls.towerEnabled.handle:SetSilent(true) 
				end)
			end
			Feature.startTowerLoop()
		end
		return "tower"

	elseif plan.kind=="island" then
		-- travel to a specific island
		local activityLock = HubState.activityLock
		if activityLock and activityLock~="quest" then 
			return "busy" 
		end
		if not claimLock("quest") then 
			return "busy" 
		end
		if Runtime.getCurrentBattle()~=nil then 
			releaseLock("quest")
			return "in-battle" 
		end
		HubState._notify("Quest: "..q.title, "ok")
		local ok = HubState.gotoIsland(plan.islandId)
		releaseLock("quest")
		return ok and "traveled" or "island-unknown"

	elseif plan.kind=="talk" then
		local activityLock = HubState.activityLock
		if activityLock and activityLock~="quest" then 
			return "busy" 
		end
		if not claimLock("quest") then 
			return "busy" 
		end
		if Runtime.getCurrentBattle()~=nil then 
			releaseLock("quest")
			return "in-battle" 
		end
		HubState._notify("Quest: "..q.title, "ok")
		local ok = HubState.talkToNpc(plan.npcId, q.taskId)
		releaseLock("quest")
		return ok and "talked" or "talk-failed"

	elseif plan.kind=="feed" then
		local ok = pcall(function() 
			return Feature.feedOnePet and Feature.feedOnePet() 
		end)
		return ok and "fed" or "feed-unavailable"

	elseif plan.kind=="ascend" then
		local ok, code = pcall(function() 
			return Feature.doAscend and Feature.doAscend() 
		end)
		if ok and code==true then 
			HubState._notify("Quest: ascended — "..q.title, "ok")
			return "ascended" 
		end
		return "ascend-not-ready"

	elseif plan.kind=="own" then
		local PS = Runtime.PetStorage
		local function lvlOf(u) local p = PS and PS.getPetList and PS.getPetList()[u]; return p and tonumber(p.level) or 0 end

		local team = teamPetUuids()
		local target = team[1]
		if not target then
			pcall(function() Feature.ownLevelPets(plan.level, plan.count) end)
			team = teamPetUuids(); target = team[1]
		end

		local function qualifyCount()
			local map = getPetMap and getPetMap(); local n=0
			if map then for _,pet in pairs(map) do if (tonumber(pet.level) or 0) >= plan.level then n+=1 end end end
			return n
		end
		if qualifyCount() >= plan.count then
			HubState.toggles._ownFeedLoop = nil; HubState._ownFeedTargetUuid = nil
			return "leveled"
		end
		if target then
			local counts = HubState.bagFruitCounts and HubState.bagFruitCounts() or {}
			local smallMed = (counts[4000021] or 0) + (counts[4000022] or 0)
			if smallMed > 300 and lvlOf(target) < plan.level then
				pcall(function() Feature.feedFruitList(target) end)   -- Small+Medium only
			end
		end
		if qualifyCount() >= plan.count then
			HubState.toggles._ownFeedLoop = nil; HubState._ownFeedTargetUuid = nil
			return "leveled"
		end

		if not HubState.toggles.autoCatch then
			HubState.toggles.autoCatch = true
			if HubState._configControls and HubState._configControls.autoCatch then
				pcall(function() HubState._configControls.autoCatch.handle:SetSilent(true) end)
			end
		end
		HubState._ownFeedTargetUuid = target
		HubState.toggles._ownFeedLoop = true 
		if not HubState.toggles.farmEnabled then
			HubState.toggles.farmEnabled = true
			if HubState._configControls and HubState._configControls.farmEnabled then
				pcall(function() HubState._configControls.farmEnabled.handle:SetSilent(true) end)
			end
			HubState.Engage.farm.start()
		end
		local cur = target and lvlOf(target) or 0
		HubState._notify("Quest: leveling slot-1 pet to Lv."..plan.level.." (now Lv."..cur..")", "ok")
		return "leveling"

	elseif plan.kind=="buyitem" then
		local ok = false
		pcall(function() ok = Feature.buyItem(plan.itemId, plan.count) end)
		return ok and "bought" or "buy-failed"

	elseif plan.kind=="dungeon" then
		-- enter the dungeon
		if HubState.activityLock and HubState.activityLock~="quest" then return "busy" end
		if not claimLock("quest") then return "busy" end
		if Runtime.getCurrentBattle()~=nil then releaseLock("quest"); return "in-battle" end
		HubState._notify("Quest: "..q.title, "ok")
		local ok = pcall(function() return Feature.enterDungeon and Feature.enterDungeon(plan.dungeonId) end)
		-- wait for the fight to resolve
		local tb=os.clock()
		while Runtime.getCurrentBattle()~=nil and os.clock()-tb<180 and not HubState._killed do task.wait(0.5) end
		releaseLock("quest")
		return ok and "dungeon" or "dungeon-failed"

	elseif plan.kind=="manual" then
		-- cannot be automated — the loop shows the warning banner; nothing to do here.
		return "manual"
	end
	return "no-plan"
end

function Feature.feedOnePet()
	if not Runtime.feedPet then return false end
	local map = getPetMap and getPetMap()
	if not map then return false end
	local SMALL = (Runtime.EXP_FRUIT and Runtime.EXP_FRUIT.SMALL) or 4000021

	-- 1) a team pet under level 30
	local team = teamPetUuids()
	local underLeveled, allTeamMaxed = nil, true
	for _,uid in ipairs(team) do
		local pet = map[uid]
		local lvl = pet and tonumber(pet.level) or 0
		if lvl < 30 then underLeveled = underLeveled or uid; allTeamMaxed = false end
	end
	if underLeveled then
		return Runtime.feedPet(underLeveled, SMALL, 1) and true or false
	end

	-- 2) all team pets >= 30 (or team empty) -> feed any inventory pet 1 Small EXP Fruit.
	--    prefer a non-locked/non-loved junk pet so we don't touch a prized one.
	local target
	for uuid,pet in pairs(map) do
		if not pet.locked and not pet.loved then target = uuid; break end
	end
	target = target or next(map)  -- fallback: literally any pet
	if not target then return false end
	return Runtime.feedPet(target, SMALL, 1) and true or false
end

-- EXP fruit itemIds and their per-fruit EXP value (largest first for efficient feeding).
local EXP_FRUITS = {
	{ id=4000039, exp=100000 },  -- Superior
	{ id=4000023, exp=10000  },  -- Large
	{ id=4000022, exp=1000   },  -- Medium
	{ id=4000021, exp=100    },  -- Small
}
-- fruit set for quest leveling: Small + Medium only (Large/Superior are spared)
local FEED_FRUITS = {
	{ id=4000022, exp=1000 },  -- Medium
	{ id=4000021, exp=100  },  -- Small
}
-- fruit counts in the bag via the game's own accessor. the old itemList walk missed fruit on
-- this build (itemList only holds currency/tickets), so it always read 0. returns { [id]=count }.
local function bagFruitCounts()
	local counts = {}
	local ids = { 4000021, 4000022, 4000023, 4000039 }
	local Bag = Runtime.BagService
	if Bag and Bag.getItemNumById then
		for _,id in ipairs(ids) do
			local ok, n = pcall(Bag.getItemNumById, id)
			counts[id] = (ok and type(n)=="number") and n or 0
		end
		return counts
	end
	-- fallback (old behavior) if BagService is missing
	local BagStorage = safeRequire(RS.Storage.BagStorage)
	local bd = BagStorage and BagStorage.getBagData and select(2, pcall(function() return BagStorage:getBagData() end))
	if type(bd)=="table" and type(bd.itemList)=="table" then
		for _,it in pairs(bd.itemList) do
			local id = it.id or it.itemId
			if id then counts[id] = (counts[id] or 0) + (it.num or it.count or 0) end
		end
	end
	return counts
end
HubState.bagFruitCounts = bagFruitCounts

-- feed the given fruit list into one pet (list order = feed order). only feeds what's in the
-- bag (server rejects over-stock with 23003). returns the pet's level after feeding.
local function feedFruitList(uid, list)
	local PS = Runtime.PetStorage
	local function lvlOf(u) local p = PS and PS.getPetList and PS.getPetList()[u]; return p and tonumber(p.level) or 0 end
	local have = bagFruitCounts()
	for _,f in ipairs(list or EXP_FRUITS) do
		local n = have[f.id] or 0
		if n > 0 then Runtime.feedPet(uid, f.id, n); task.wait(0.4) end
	end
	return lvlOf(uid)
end
-- feed every fruit type (non-quest callers); quest leveling uses FEED_FRUITS instead
local function feedAllBagFruit(uid)
	return feedFruitList(uid, EXP_FRUITS)
end
-- exposed for the farm loop's 1-by-1 feed; defaults to Small+Medium only
function Feature.feedFruitList(uid, list)
	return feedFruitList(uid, list or FEED_FRUITS)
end

-- Set of pet uuids currently in the active team (they CANNOT be released — reqRemovePets
-- returns 38303 PET_IN_GROUP for them).
local function teamUuidSet()
	local set = {}
	local PGS = Runtime.PetGroupService
	if PGS and PGS.getCurrentGroupId and PGS.getPetGroupByGroupId then
		local gid = select(2, pcall(PGS.getCurrentGroupId))
		local grp = select(2, pcall(PGS.getPetGroupByGroupId, gid))
		if type(grp)=="table" and type(grp.petUuids)=="table" then
			for _,u in pairs(grp.petUuids) do set[u]=true end
		end
	end
	return set
end

-- Release every non-kept junk pet EXCEPT `protectUid` and team pets, converting them to EXP
-- fruit in the bag. Respects the same keep rules as autoReleasePass. NOTE: low-level junk
-- yields almost NO fruit (fruit scales with the released pet's total EXP × PET_RELEASE_EXP_RATIO
-- = 70%), so this is a minor top-up; the main leveling driver is battle EXP (team + farm).
-- Returns how many were released.
function Feature.releaseJunkForFruit(protectUid)
	local PS = Runtime.PetService
	if not (PS and PS.reqRemovePets) then return 0 end
	local map = getPetMap(); if not map then return 0 end
	local tg = HubState.toggles
	local inTeam = teamUuidSet()
	local released = 0
	for uuid, pet in pairs(map) do
		if HubState._killed then break end
		if uuid ~= protectUid and not inTeam[uuid] then
			local shiny, prism, grade = petIsShiny(pet), petIsPrismatic(pet), petGrade(pet)
			local keep = pet.locked or pet.loved
				or (tg.keepShiny and shiny) or (tg.keepPrismatic and prism)
				or (grade and tg.keepGrades and tg.keepGrades[grade])
			local lockProtected = (tg.autoLockShiny and shiny) or (tg.autoLockPrismatic and prism) or (tg.autoLockSSS and grade=="SSS")
			if not keep and not lockProtected then
				local ok,code = pcall(PS.reqRemovePets, { uuid })
				if ok and code==20000 then released += 1 end
				task.wait(0.15)
			end
		end
	end
	return released
end

-- level a pet toward targetLv: feed Small+Medium on hand, then release junk -> fruit -> feed.
-- returns the level reached (may be short if no fruit + no junk; the quest loop retries).
function Feature.levelPetTo(uid, targetLv)
	if not (Runtime.feedPet and uid and targetLv) then return 0 end
	local PS = Runtime.PetStorage
	local function lvlOf(u) local p = PS and PS.getPetList and PS.getPetList()[u]; return p and tonumber(p.level) or 0 end
	if lvlOf(uid) >= targetLv then return lvlOf(uid) end
	-- round 1: feed the Small+Medium fruit we already have
	if feedFruitList(uid, FEED_FRUITS) >= targetLv then return lvlOf(uid) end
	-- rounds 2-3: release junk -> fruit -> feed
	for round=1,2 do
		if HubState._killed or lvlOf(uid) >= targetLv then break end
		local freed = Feature.releaseJunkForFruit(uid)
		if freed > 0 then
			task.wait(0.5)   -- let the release rewards land in the bag
			if feedFruitList(uid, FEED_FRUITS) >= targetLv then break end
		else
			break   -- nothing left to release; give up this pass
		end
	end
	return lvlOf(uid)
end

-- Put `uid` into the current pet team (slot 1) so it gains battle EXP while farming, without
-- disturbing the rest of the team. Uses reqSetPetGroup(groupId, petUuids). Idempotent.
function Feature.ensurePetInTeam(uid)
	local PGS = Runtime.PetGroupService
	if not (PGS and PGS.getCurrentGroupId and PGS.reqSetPetGroup) then return false end
	local gid = select(2, pcall(PGS.getCurrentGroupId))
	local grp = select(2, pcall(PGS.getPetGroupByGroupId, gid))
	if type(grp)~="table" or type(grp.petUuids)~="table" then return false end
	-- already in team?
	for _,u in pairs(grp.petUuids) do if u==uid then return true end end
	-- put it in slot 1 (bump others down); keep it simple: replace slot 1
	local newUuids = {}
	for slot,u in pairs(grp.petUuids) do newUuids[slot]=u end
	newUuids[1] = uid
	local ok = pcall(PGS.reqSetPetGroup, gid, newUuids)
	return ok
end

-- Satisfy a PET_OWNED / PET_LEVEL_REACH goal: ensure `count` pets are at >= `level`.
-- Prefer pets ALREADY closest to the target (least waste); never touch locked/loved unless
-- we must. Levels them one at a time via Feature.levelPetTo. Returns how many now qualify.
function Feature.ownLevelPets(level, count)
	local map = getPetMap and getPetMap()
	if not map then return 0 end
	count = count or 1
	-- already-qualifying
	local qualify, candidates = {}, {}
	for uid,pet in pairs(map) do
		local lv = tonumber(pet.level) or 0
		if lv >= level then qualify[#qualify+1]=uid
		else candidates[#candidates+1]={uid=uid, lv=lv, locked=pet.locked or pet.loved} end
	end
	if #qualify >= count then return #qualify end
	-- sort candidates: highest level first (closest to target), unlocked before locked
	table.sort(candidates, function(a,b)
		if a.locked ~= b.locked then return not a.locked end
		return a.lv > b.lv
	end)
	local need = count - #qualify
	for i=1,math.min(need, #candidates) do
		if HubState._killed then break end
		pcall(function() Feature.ensurePetInTeam(candidates[i].uid) end)
		local lv = Feature.levelPetTo(candidates[i].uid, level)   -- feeds bag fruit if any
		if lv >= level then qualify[#qualify+1]=candidates[i].uid end
	end
	return #qualify
end

-- Buy an item from a shop (ITEM_OBTAIN goals, e.g. "Buy an Advanced Ball"). Tries the
-- ShopService purchase path. itemId is the ITEM id; shops key goods by a goodsId, so we
-- resolve the goods entry whose itemId matches, then applyPurchaseGoods.
function Feature.buyItem(itemId, count)
	local Shop = Runtime.ShopService
	if not (Shop and itemId) then return false end
	count = count or 1
	-- best-effort: many builds accept applyPurchaseGoods(goodsId, num). We look up a goods row
	-- whose reward/item matches itemId via GoodsConfig.
	local CDM, CCn = Runtime.ConfigDataManager, Runtime.ConfigConst
	local goodsId
	if CDM and CCn and CCn.ConfigName.GOODS then
		local ok, goodsTbl = pcall(CDM.getTable, CCn.ConfigName.GOODS)
		if ok and type(goodsTbl)=="table" then
			for gid,row in pairs(goodsTbl) do
				if type(row)=="table" then
					local rid = row.itemId or row.goodsItemId or (type(row.reward)=="table" and row.reward.itemId)
					if rid==itemId then goodsId=gid; break end
				end
			end
		end
	end
	if not goodsId then return false end
	if Shop.applyPurchaseGoods then
		local ok = pcall(Shop.applyPurchaseGoods, goodsId, count)
		return ok
	end
	return false
end

function Feature.doAscend()
	local LV = Runtime.LvService
	if not (LV and LV.reqLevelBreakthrough) then return false end
	local ok, code = pcall(LV.reqLevelBreakthrough)
	return ok and (code==20000 or code==true)
end

function Feature.enterDungeon(dungeonId)
	if not Runtime.enterDungeon then return false end
	local id = dungeonId
	if typeof(id)=="table" then id = id[1] end
	if typeof(id)~="number" then return false end
	local ok = pcall(Runtime.enterDungeon, id)
	return ok and true or false
end

