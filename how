-- Auto-do quest tracks state so we don't thrash toggles: when the driver switches a
-- quest away from a farm/hunt/tower action, it clears the flags it set so the next
-- quest's action starts clean. We only auto-manage flags that Auto Quest itself enabled.
local questDrive = { farmByQuest=false, shinyByQuest=false, prismByQuest=false, towerByQuest=false,
	skillByQuest=false, switchByQuest=false, lastTaskId=nil }

-- Auto Do Quest must be able to WIN the battles
local function ensureQuestCombat()
	local tg = HubState.toggles
	if not tg.autoSkill then
		tg.autoSkill = true; questDrive.skillByQuest = true
		if HubState._configControls and HubState._configControls.autoSkill then
			pcall(function() HubState._configControls.autoSkill.handle:SetSilent(true) end) end
	end
	if not tg.autoSwitchDeadPet then
		tg.autoSwitchDeadPet = true; questDrive.switchByQuest = true
		if HubState._configControls and HubState._configControls.autoSwitchDeadPet then
			pcall(function() HubState._configControls.autoSwitchDeadPet.handle:SetSilent(true) end) end
	end
end

local function clearQuestDrivenFlags()
	if questDrive.farmByQuest then HubState.toggles.farmEnabled=false; questDrive.farmByQuest=false
		if HubState._configControls and HubState._configControls.farmEnabled then
			pcall(function() HubState._configControls.farmEnabled.handle:SetSilent(false) end) end
	end
	if questDrive.shinyByQuest then HubState.toggles.autoCatchShiny=false; questDrive.shinyByQuest=false end
	if questDrive.prismByQuest then HubState.toggles.autoCatchPrismatic=false; questDrive.prismByQuest=false end
	if questDrive.towerByQuest then HubState.toggles.towerEnabled=false; questDrive.towerByQuest=false
		if HubState._configControls and HubState._configControls.towerEnabled then
			pcall(function() HubState._configControls.towerEnabled.handle:SetSilent(false) end) end
	end
	if questDrive.skillByQuest then HubState.toggles.autoSkill=false; questDrive.skillByQuest=false
		if HubState._configControls and HubState._configControls.autoSkill then
			pcall(function() HubState._configControls.autoSkill.handle:SetSilent(false) end) end
	end
	if questDrive.switchByQuest then HubState.toggles.autoSwitchDeadPet=false; questDrive.switchByQuest=false
		if HubState._configControls and HubState._configControls.autoSwitchDeadPet then
			pcall(function() HubState._configControls.autoSwitchDeadPet.handle:SetSilent(false) end) end
	end
	-- clear own-leveling flags + learned family stats
	HubState.toggles._ownFeedLoop = nil
	HubState._ownFeedTargetUuid = nil
	if HubState.OpponentPicker then pcall(HubState.OpponentPicker.reset) end
end

do
	local running=false
	function Feature.startQuestLoop()
		if running then return end
		running=true
		task.spawn(function()
			while not HubState._killed do
				local tg = HubState.toggles
				if tg.autoClaimQuests or tg.autoDoQuest then
					local n = claimCompletedTasks()
					pcall(claimActiveMilestone)
					if n and n>0 then HubState._notify("Quests: claimed "..n, "ok") end
				end
				if tg.autoDoQuest then
					local work = questWorkList()
					local chosen, chosenPlan, firstManual
					for _,q in ipairs(work) do
						local plan = planQuestAction(q)
						if plan then
							if plan.kind=="manual" then
								if not firstManual then firstManual = { q=q, plan=plan } end
							else
								chosen=q; chosenPlan=plan; break
							end
						end
					end
					if chosen then
						-- an actionable quest exists -> hide any warning banner
						pcall(Feature.hideQuestWarning)
						if questDrive.lastTaskId ~= chosen.taskId then
							clearQuestDrivenFlags()
							questDrive.lastTaskId = chosen.taskId
						end
						-- record which flags this action turns on
						if chosenPlan.kind=="farm" then questDrive.farmByQuest = not tg.farmEnabled or questDrive.farmByQuest
						elseif chosenPlan.kind=="shiny" then questDrive.shinyByQuest=true; questDrive.farmByQuest = not tg.farmEnabled or questDrive.farmByQuest
						elseif chosenPlan.kind=="prismatic" then questDrive.prismByQuest=true; questDrive.farmByQuest = not tg.farmEnabled or questDrive.farmByQuest
						elseif chosenPlan.kind=="tower" then questDrive.towerByQuest = not tg.towerEnabled or questDrive.towerByQuest end
						-- any combat-driving quest needs Auto Skill + Auto Switch on to actually WIN
						local combatKinds = { farm=true, shiny=true, prismatic=true, challenge=true,
							anyNpc=true, anyBoss=true, tower=true, dungeon=true, own=true }
						if combatKinds[chosenPlan.kind] then ensureQuestCombat() end
						pcall(driveQuestAction, chosenPlan, chosen)
					elseif firstManual then
						clearQuestDrivenFlags()
						questDrive.lastTaskId = nil
						pcall(Feature.showQuestWarning, firstManual.q.title)
					else
						clearQuestDrivenFlags()
						questDrive.lastTaskId = nil
						pcall(Feature.hideQuestWarning)
					end
				elseif questDrive.lastTaskId ~= nil then
					clearQuestDrivenFlags()
					questDrive.lastTaskId = nil
					pcall(Feature.hideQuestWarning)
				else
					pcall(Feature.hideQuestWarning)
				end
				-- battle actions pace themselves
				task.wait(3)
			end
			running=false
		end)
	end
end

