local Pacing = { mode="normal" }
do
	local mbw = Runtime.getController("MainBattleWindowController")
	Pacing._mbw = mbw
	Pacing._origSpeedFn = mbw and mbw.getBattlePlaybackSpeed
	local bcc = findModule("BattleChoreoConst")
	Pacing._BCC = bcc and safeRequire(bcc)
	Pacing._origWaits = {}       -- numeric top-level delay constants
	Pacing._origWaitTbls = {}    -- by-type delay tables (per-action / per-settle-node)
	if Pacing._BCC then
		for _,k in ipairs({"DefaultActionWaitTime","SettleNodeWaitTime","StartBattleBeforeChoreographyDelayTime",
			"FirstRoundEmptyActionResultsAnimationCompleteDelay","ForceSwitchAnimationCompleteDelay",
			"OpeningThrowBallPreDelay","OpeningThrowBallPostDelay"}) do
			Pacing._origWaits[k] = Pacing._BCC[k]
		end
		for _,k in ipairs({"ActionWaitTimeByType","SettleNodeWaitTimeByType"}) do
			if typeof(Pacing._BCC[k])=="table" then
				local save = {}
				for kk,v in pairs(Pacing._BCC[k]) do if typeof(v)=="number" then save[kk]=v end end
				Pacing._origWaitTbls[k] = save
			end
		end
	end
end

function Pacing:setWaits(scale)
	if not self._BCC then return end
	for k,orig in pairs(self._origWaits) do
		if typeof(orig)=="number" then self._BCC[k] = orig * scale end
	end
	for k,saved in pairs(self._origWaitTbls or {}) do
		if typeof(self._BCC[k])=="table" then
			for kk,orig in pairs(saved) do self._BCC[k][kk] = orig * scale end
		end
	end
end

function Pacing:_waitScaleForMode()
	if self.mode=="autoSkip" then return 0.2 end
	if self.mode=="fastBattle" then return 0 end 
	return 1
end

function Pacing:_speedForMode()
	if self.mode=="normal" then return nil end -- use native
	if self.mode=="fastBattle" then return 8 end
	return 2
end

-- Battle-speed bypass levers
function Pacing:installReporterHook()
	if self._reporterHooked then return end
	local R = Runtime.AnimCompleteReporter
	if not (R and typeof(R.beginExpectation)=="function" and typeof(R.reportComplete)=="function") then return end
	self._origBeginExpectation = R.beginExpectation
	R.beginExpectation = function(uid, round, ...)
		self._origBeginExpectation(uid, round, ...)
		task.defer(function() pcall(function() R.reportComplete(uid, round, "jinhub_fast") end) end)
	end
	self._reporterHooked = true
end
function Pacing:removeReporterHook()
	if not self._reporterHooked then return end
	local R = Runtime.AnimCompleteReporter
	if R and self._origBeginExpectation then pcall(function() R.beginExpectation = self._origBeginExpectation end) end
	self._reporterHooked = false
end

function Pacing:installOpeningSkip()
	if self._openingHooked then return end
	local mbw = self._mbw or Runtime.getController("MainBattleWindowController")
	self._mbw = mbw
	if not (mbw and typeof(mbw.playBattleMainEnterAnimation)=="function") then return end
	self._origMainEnter = mbw.playBattleMainEnterAnimation
	mbw.playBattleMainEnterAnimation = function(cb, ...)
		if typeof(cb)=="function" then task.defer(cb) end   -- fire entrance-done at once, no animation
	end
	self._openingHooked = true
end
function Pacing:removeOpeningSkip()
	if not self._openingHooked then return end
	local mbw = self._mbw or Runtime.getController("MainBattleWindowController")
	if mbw and self._origMainEnter then pcall(function() mbw.playBattleMainEnterAnimation = self._origMainEnter end) end
	self._openingHooked = false
end

function Pacing:installSwitchSkip()
	if self._switchHooked then return end
	local vfx = Runtime.BattleNPCVisualEffectController
	if not (vfx and typeof(vfx.playThrowBall)=="function" and typeof(vfx.playCatchBall)=="function") then return end
	self._origPlayThrowBall = vfx.playThrowBall
	self._origPlayCatchBall = vfx.playCatchBall
	vfx.playThrowBall = function(p1, p2, p3, p4)
		if typeof(p3)=="function" then task.defer(p3) end
	end
	vfx.playCatchBall = function(p1, p2, p3, p4, p5)
		if typeof(p4)=="function" then task.defer(p4) end
	end
	self._switchHooked = true
end
function Pacing:removeSwitchSkip()
	if not self._switchHooked then return end
	local vfx = Runtime.BattleNPCVisualEffectController
	if vfx then
		if self._origPlayThrowBall then pcall(function() vfx.playThrowBall = self._origPlayThrowBall end) end
		if self._origPlayCatchBall then pcall(function() vfx.playCatchBall = self._origPlayCatchBall end) end
	end
	self._switchHooked = false
end

function Pacing:zeroSkillFinishWaitTimes()
	if self._skillWaitZeroed then return end
	local Cfg = Runtime.SkillPerformanceCfg
	if typeof(Cfg) ~= "table" then return end
	self._skillWaitOrig = {}
	for skillId, cfg in pairs(Cfg) do
		if typeof(cfg)=="table" and typeof(cfg.finishWaitTime)=="number" then
			self._skillWaitOrig[skillId] = cfg.finishWaitTime
			cfg.finishWaitTime = 0
		end
	end
	self._skillWaitZeroed = true
end
function Pacing:restoreSkillFinishWaitTimes()
	if not self._skillWaitZeroed then return end
	local Cfg = Runtime.SkillPerformanceCfg
	if typeof(Cfg)=="table" then
		for skillId, orig in pairs(self._skillWaitOrig or {}) do
			local cfg = Cfg[skillId]
			if typeof(cfg)=="table" then cfg.finishWaitTime = orig end
		end
	end
	self._skillWaitOrig = {}
	self._skillWaitZeroed = false
end

function Pacing:installCaptureSkip()
	if self._captureHooked then return end
	local ctrl = Runtime.getController("CaptureNotificationController")
	if not (ctrl and typeof(ctrl.openWindow)=="function") then return end
	self._origOpenWindow = ctrl.openWindow
	ctrl.openWindow = function(p1, p2, p3, p4)
		if typeof(p3)=="function" then task.defer(p3) end
		return 0 -- ErrorCode.SUCCEEDED
	end
	self._captureCtrl = ctrl
	self._captureHooked = true
end
function Pacing:removeCaptureSkip()
	if not self._captureHooked then return end
	if self._captureCtrl and self._origOpenWindow then
		pcall(function() self._captureCtrl.openWindow = self._origOpenWindow end)
	end
	self._captureHooked = false
end

function Pacing:_speedStateTable()
	if self._speedState ~= nil then return self._speedState or nil end
	local mbw = self._mbw or Runtime.getController("MainBattleWindowController")
	self._mbw = mbw
	local ok, tbl = pcall(function()
		if mbw and typeof(mbw.isBattleSpeedEnabled)=="function" and debug and debug.getupvalue then
			local v = debug.getupvalue(mbw.isBattleSpeedEnabled, 1)
			if typeof(v)=="table" then return v end
		end
		return nil
	end)
	self._speedState = (ok and typeof(tbl)=="table") and tbl or false
	return self._speedState or nil
end
function Pacing:reassertSpeedFlag()
	if self.mode ~= "fastBattle" and self.mode ~= "speed2x" then return end
	local st = self:_speedStateTable()
	if st then st.battleSpeedEnabled = true end
end
function Pacing:enableServer2x()
	local st = self:_speedStateTable()
	if st then st.battleSpeedEnabled = true end
	if Runtime.SettingService and typeof(Runtime.SettingService.ReqUpdateSetting)=="function" then
		pcall(function() Runtime.SettingService.ReqUpdateSetting("BattleSpeed", 1) end)
	end
end
function Pacing:disableServer2x()
	local st = self:_speedStateTable()
	if st then st.battleSpeedEnabled = false end
	if Runtime.SettingService and typeof(Runtime.SettingService.ReqUpdateSetting)=="function" then
		pcall(function() Runtime.SettingService.ReqUpdateSetting("BattleSpeed", 0) end)
	end
end

function Pacing:restoreAll()
	self:removeReporterHook()
	self:removeOpeningSkip()
	self:removeSwitchSkip()
	self:removeCaptureSkip()
	pcall(function() if self._mbw and self._origSpeedFn then self._mbw.getBattlePlaybackSpeed = self._origSpeedFn end end)
	pcall(function() self:setWaits(1) end)
	pcall(function() self:restoreSkillFinishWaitTimes() end)
	pcall(function() self:disableServer2x() end)
end

function Pacing:apply(mode)
	self.mode = mode
	HubState.toggles.fastBattle    = (mode=="fastBattle")
	HubState.toggles.battleSpeed2x = (mode=="speed2x")
	HubState.toggles.autoSkipNormal= (mode=="autoSkip")
	local mbw = self._mbw or Runtime.getController("MainBattleWindowController")
	self._mbw = mbw
	local sp = self:_speedForMode()
	if mbw then
		if sp then mbw.getBattlePlaybackSpeed = function() return sp end
		elseif self._origSpeedFn then mbw.getBattlePlaybackSpeed = self._origSpeedFn end
	end
	if mode=="fastBattle" then
		self:installReporterHook()
		self:installOpeningSkip()
		self:installSwitchSkip()
		self:installCaptureSkip()
		self:enableServer2x()
	elseif mode=="speed2x" then
		self:removeReporterHook()
		self:removeOpeningSkip()
		self:removeSwitchSkip()
		self:removeCaptureSkip()
		self:enableServer2x()
	else
		self:removeReporterHook()
		self:removeOpeningSkip()
		self:removeSwitchSkip()
		self:removeCaptureSkip()
		self:disableServer2x()
	end
	if Runtime.getCurrentBattle()==nil then
		self:setWaits(self:_waitScaleForMode())
		if mode=="fastBattle" then self:zeroSkillFinishWaitTimes() else self:restoreSkillFinishWaitTimes() end
	end
end

-- called by BattleLoo
function Pacing:onBattleBoundary()
	self:setWaits(self:_waitScaleForMode())
	if self.mode=="fastBattle" then self:zeroSkillFinishWaitTimes() else self:restoreSkillFinishWaitTimes() end
end

