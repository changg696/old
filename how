			else lbl, val = tostring(o), o end
			labels[#labels+1] = lbl
			valueOf[lbl] = val
			labelOf[tostring(val)] = lbl
		end
		return labels
	end
	local labels = rebuildMaps(config.options or {})
	local defaultVal = config.default
	local defaultLabel = (defaultVal~=nil and labelOf[tostring(defaultVal)]) or (labels[1])
	
	local suppress = false
	local windDrop = section:Dropdown({
		Title = config.title or "",
		Desc = config.desc or "",
		Values = labels,
		Value = defaultLabel or "",
		Callback = function(label)
			if suppress then return end
			if config.onChange then task.spawn(config.onChange, valueOf[label], label) end
		end
	})
	
	return {
		SetOptions = function(_, newOpts, keepSel)
			local prevLabel = windDrop.Value
			labels = rebuildMaps(newOpts)
			suppress = true
			pcall(function() windDrop:Refresh(labels) end)
			if keepSel and prevLabel and valueOf[prevLabel]~=nil then
				pcall(function() windDrop:Select(prevLabel) end)
			else
				pcall(function() windDrop:Select(labels[1] or "") end)
			end
			suppress = false
		end,
		Set = function(_, value, fire)
			local lbl = labelOf[tostring(value)]
			if not lbl then return end
			suppress = (fire==false)
			pcall(function() windDrop:Select(lbl) end)
			suppress = false
		end,
		Get = function(_)
			local lbl = windDrop.Value
			return valueOf[lbl], lbl
		end,
	}
end

