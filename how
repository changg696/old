-- is the given boss currently challengeable (refreshTime in the past / no entry)?
function Feature.isBossAvailable(npcId)
	local RSvc = Runtime.RefreshService
	if not (RSvc and RSvc.getBossRefreshInfoList) then return true end -- unknown -> assume yes
	local ok, list = pcall(RSvc.getBossRefreshInfoList)
	if not ok or typeof(list)~="table" then return true end
	local now = workspace:GetServerTimeNow()
	for _,e in ipairs(list) do
		if e.npcId==npcId then return now >= (e.refreshTime or 0) end
	end
	return true -- no entry => never defeated / already up
end
