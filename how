-- ---- Auto-Quest drivers
do
	-- Dungeon enter (verified: Remote/Dungeon/ReqEnterDungeon, RemoteFunction, 1 arg dungeonId)
	local reqEnterDungeon = findRemote("ReqEnterDungeon", "RemoteFunction")
	local DungeonService = safeRequire(RS.Script.Dungeon.DungeonService)
	if reqEnterDungeon then
		Runtime.enterDungeon = function(dungeonId)
			return reqEnterDungeon:InvokeServer(dungeonId)
		end
	elseif DungeonService and DungeonService.applyEnterDungeon then
		Runtime.enterDungeon = function(dungeonId)
			return DungeonService.applyEnterDungeon(dungeonId)
		end
	end

	-- Pet "feed" (PET_FEED goal) = use an EXP fruit on a pet. Verified path:
	--   PetService.reqPetAddExpByItems(petUid, { {id=<itemId>, num=<count>}, ... })
	-- Small EXP Fruit = itemId 4000021 (100 EXP). feedPet(uid, itemId, num) feeds `num`
	-- fruits of `itemId` to the pet uid. Returns true on ErrorCode.SUCCEEDED(20000).
	local PetSvc = Runtime.PetService or safeRequire(RS.Script.Pet.PetService)
	Runtime.EXP_FRUIT = { SMALL=4000021, MEDIUM=4000022, LARGE=4000023, SUPERIOR=4000039 }
	-- item counts via the game's own accessor (bagFruitCounts uses getItemNumById)
	Runtime.BagService = Runtime.BagService or safeRequire(RS.Script.Bag.BagService)
	if PetSvc and PetSvc.reqPetAddExpByItems then
		Runtime.feedPet = function(uuid, itemId, num)
			itemId = itemId or Runtime.EXP_FRUIT.SMALL
			num = num or 1
			local ok, r = pcall(PetSvc.reqPetAddExpByItems, uuid, { { id=itemId, num=num } })
			return ok and (r==20000 or r==true)
		end
	else
		local addExpRemote = findRemote("ReqPetAddExpByItems", "RemoteFunction")
		if addExpRemote then
			Runtime.feedPet = function(uuid, itemId, num)
				itemId = itemId or Runtime.EXP_FRUIT.SMALL
				local ok, r = pcall(function() return addExpRemote:InvokeServer(uuid, { { id=itemId, num=num or 1 } }) end)
				return ok and (r==20000 or r==true)
			end
		end
	end

	-- NPC talk / dialogue-advance. The real path (verified via DialogueWindowController):
	--   ReqMarkDialogueTalkCompleted:FireServer(talkId)   -- marks a dialogue node done
	--   ReqCompleteDialogueTask:Invoke(talkId, taskId)    -- submits a talk-quest turn-in
	-- A TALK_TO_NPC goal completes once the npc's initial-dialogue talk nodes are marked
	-- complete. We resolve the npc's talk graph from NpcConfig.npcInitialDialogueId (a
	-- {worldId -> firstTalkId} map) and TalkConfig.nextTalkIds, then mark each node.
	Runtime.ReqMarkDialogueTalkCompleted = findRemote("ReqMarkDialogueTalkCompleted", "RemoteEvent")
	Runtime.ReqCompleteDialogueTask      = findRemote("ReqCompleteDialogueTask", "RemoteFunction")
	Runtime.ReqReceiveDialogueTask       = findRemote("ReqReceiveDialogueTask", "RemoteFunction")
	if Runtime.ReqMarkDialogueTalkCompleted then
		Runtime.talkToNpc = function(npcId, taskId)
			local CDM, CC = Runtime.ConfigDataManager, Runtime.ConfigConst
			if not (CDM and CC) then return false end
			local okC, npcCfg = pcall(CDM.getConfig, CC.ConfigName.NPC, npcId)
			if not (okC and type(npcCfg)=="table") then return false end
			-- collect the initial talk ids (per world) then walk nextTalkIds chains
			local firstIds = {}
			if type(npcCfg.npcInitialDialogueId)=="table" then
				for _,v in pairs(npcCfg.npcInitialDialogueId) do
					local n = tonumber(v); if n then firstIds[#firstIds+1] = n end
				end
			end
			local marked, seen = false, {}
			local function walk(talkId, depth)
				if not talkId or seen[talkId] or depth>12 then return end
				seen[talkId] = true
				pcall(function() Runtime.ReqMarkDialogueTalkCompleted:FireServer(talkId) end)
				marked = true
				local okT, talkCfg = pcall(CDM.getConfig, CC.ConfigName.TALK, talkId)
				if okT and type(talkCfg)=="table" then
					-- submit a talk-quest turn-in if this node carries a taskId
					if Runtime.ReqCompleteDialogueTask and (talkCfg.taskId or taskId) then
						pcall(function() Runtime.ReqCompleteDialogueTask:Invoke(talkId, talkCfg.taskId or taskId) end)
					end
					if type(talkCfg.nextTalkIds)=="table" then
						for _,nt in ipairs(talkCfg.nextTalkIds) do walk(tonumber(nt), depth+1) end
					end
				end
			end
			for _,fid in ipairs(firstIds) do walk(fid, 0) end
			return marked
		end
	end
end




