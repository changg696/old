local function walkAndEngageWild(uid, worldPos)
	if Runtime.BattleService and Runtime.BattleService.canEnterBattle then
		local ok,code = pcall(Runtime.BattleService.canEnterBattle, 1)
		if ok and code ~= 20000 then
			pcall(function() HubState.repairBattleDesync() end)
